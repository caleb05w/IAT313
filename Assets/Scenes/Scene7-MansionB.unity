  - flag: event5:confront2
    dialogue:
      showDialogue: 1
      lines:
      - characterName: 'Belladonna:'
        text: Stop.
        flagOnComplete: 
      - characterName: 'Hemlock:'
        text: ...!
        flagOnComplete: 
      - characterName: 'Belladonna:'
        text: "You look lost and conflicted dear, perhaps you\u2019re not supposed
          to be here?"
        flagOnComplete: 
      - characterName: 'Hemlock:'
        text: S-Shut up! I was sent here to kill you.
        flagOnComplete: 
      - characterName: 'Belladonna:'
        text: "Heehee, oh I\u2019m sure you were"
        flagOnComplete: 
      - characterName: 'Belladonna:'
        text: "Another one of Felix\u2019s misguided pawns."
        flagOnComplete: 
      - characterName: 'Belladonna:'
        text: Alright then... do your worst, thug.
        flagOnComplete: event6:confront3
    oneShot: 0
    hasFired: 0
