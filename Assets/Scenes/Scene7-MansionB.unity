  m_Script: {fileID: 11500000, guid: 7722afbe78a714ded844e7f272ad1ebd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogue:
    showDialogue: 1
    lines:
    - characterName: Boss Man
      text: Took your sweet time with this one hmm?
      flagOnComplete: 
    - characterName: Dahlia
      text: "I\u2019m sorry sir, I got caught up in-."
      flagOnComplete: 
    - characterName: Boss Man
      text: Enough. Spare me the excuses.
      flagOnComplete: 
    - characterName: Boss Man
      text: Did you bring proof of death?
      flagOnComplete: 
    - characterName: Dahlia
      text: Y-yes... here you go
      flagOnComplete: 
    - characterName: Boss Man
      text: "Hmm... very good\u201D"
      flagOnComplete: 
    - characterName: Boss Man
      text: One less meddlesome investigator looking into our business.
      flagOnComplete: 
    - characterName: Boss Man
      text: "You\u2019re going to assist your fellow cut-throat Harry in assailing
        a high profile target tomorrow."
      flagOnComplete: 
    - characterName: Dahlia
      text: Umm, who exactly?
      flagOnComplete: 
    - characterName: Boss Man
      text: "That doesn\u2019t concern you Hemlock"
      flagOnComplete: 
    - characterName: Boss Man
      text: "Remember your place, you\u2019re nothing more than a violent tool. Don\u2019t
        ask such pointless questions"
      flagOnComplete: 
    - characterName: Dahlia
      text: Apologies sir, I-
      flagOnComplete: 
    - characterName: Boss Man
      text: "That will be all, you\u2019re dismissed."
      flagOnComplete: 
  flagDialogues: []
  flagToSet: 
  flagOnComplete: event4:finishTalkToBoss
  oneShot: 0
  endDialogueOnExit: 1
  wander: {fileID: 0}
  onComplete:
    m_PersistentCalls:
      m_Calls: []
