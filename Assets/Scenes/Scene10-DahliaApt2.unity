  m_Script: {fileID: 11500000, guid: f5751978dfa734eea81e24a0dec56305, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CutscenePlayer
  playOnStart: 1
  startSlides:
  - layout: 0
    image: {fileID: 0}
    text: After a long day of troubled thoughts, Dahlia returns home seeking solidarity.
    rollingText: 1
    highlights:
    - word: Dahlia
      color: {r: 0.4627451, g: 0.6117647, b: 0.33333334, a: 0}
    sounds: []
  - layout: 0
    image: {fileID: 0}
    text: 'As she arrives home, something seems dangerously amiss... '
    rollingText: 1
    highlights: []
    sounds: []
  slides:
  - layout: 1
    image: {fileID: 4345347192318643893, guid: 6f16acb8e07e14dc6a353547e70aa5a3, type: 3}
    text: "The cold steel of Hemlock\u2019s blade pierces an unknowing investigators
      flesh."
    rollingText: 1
    highlights:
    - word: Hemlock
      color: {r: 0.4627451, g: 0.6117647, b: 0.33333334, a: 0}
    sounds: []
  - layout: 1
    image: {fileID: 4345347192318643893, guid: 6f16acb8e07e14dc6a353547e70aa5a3, type: 3}
    text: A victim is claimed in the dead of night, without a witness in sight.
    rollingText: 1
    highlights: []
    sounds: []
  - layout: 0
    image: {fileID: 0}
    text: "Leaving the site of the scene, she vanishes swiftly through the narrow
      alley roads.\n\nThrough the thick fog, she arrives at the iron gate of a grand
      mansion, the guards let Hemlock in as she is escorted to Alfonso\u2019s office."
    rollingText: 1
    highlights:
    - word: Hemlock
      color: {r: 0.4627451, g: 0.6117647, b: 0.33333334, a: 0}
    - word: Alfonso
      color: {r: 0.9843137, g: 0.45490196, b: 0.45490196, a: 0}
    sounds: []
  textOnlyLayout: {fileID: 1089675215}
  textOnlyDialogue: {fileID: 1044548151}
  textOnlyProceed: {fileID: 236206683}
  textWithImageLayout: {fileID: 1067687927}
  displayImage: {fileID: 1537518975}
  textWithImageDialogue: {fileID: 2082054138}
  textWithImageProceed: {fileID: 236206683}
