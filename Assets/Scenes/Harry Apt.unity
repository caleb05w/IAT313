  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ConditionalInteractable
  requiresItems: 1
  requiredItems: []
  consumeItemsOnSuccess: 0
  requiredFlag: 
  setFlagOnSuccess: readJournal
  successDialogue:
    showDialogue: 1
    dialogueText:
    - "How long must this go on? I think I\u2019m at wit\u2019s end."
    - "The screams of the innocent lives I\u2019ve taken haunt my dream every night.
      The guilt is unbearable."
    - "I can\u2019t even imagine what a normal life could have been like."
    - "Maybe I should tell Dhalia, I\u2019ve got to find a way to break the cycle
      before its too late."
    - A note is left at the end of the journal entry
    - Check the closet Dhalia.
    characterName: Harry's Diary
  missingItemDialogue:
    showDialogue: 0
    dialogueText:
    - The fires cold. You should light it.
    characterName: 
  missingFlagDialogue:
    showDialogue: 0
    dialogueText: []
    characterName: 
  onSuccess:
    m_PersistentCalls:
      m_Calls: []
  onFail:
    m_PersistentCalls:
      m_Calls: []
